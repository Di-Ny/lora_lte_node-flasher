#!/usr/bin/env bash
#
# pre-push hook : auto-bump du compteur 'Flasher #N' UNIQUEMENT quand
# l'outil de flashage lui-meme a evolue (pas pour les releases firmware).
#
# Le compteur 'Flasher #N' = version de l'OUTIL de flashage (UI + scripts).
# Il NE doit PAS monter quand on publie juste une nouvelle release firmware
# (qui ajoute des .bin/manifests sans toucher au code du flasher).
#
# Logique :
#   - On regarde la liste des fichiers modifies par les commits a pusher
#   - Si TOUS les changements concernent uniquement firmware/, manifests/
#     ou builds.json -> c'est une release firmware -> PAS de bump
#   - Si au moins un fichier du flasher (index.html, README.md, scripts/,
#     LICENSE, NOTICE, .gitignore, etc.) a change -> BUMP
#
# Installation (a faire une fois par clone) :
#   git config core.hooksPath scripts/git-hooks
#
# Pour desactiver temporairement (push sans considerer le bump) :
#   git push --no-verify
#
# Pour FORCER un bump manuel (par exemple si tu veux marquer une version) :
#   echo "$(( $(cat .flasher-version) + 1 ))" > .flasher-version
#   # puis edit index.html (BUILD_TAG_START/END), commit et push normalement

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$REPO_ROOT/.flasher-version"
INDEX_HTML="$REPO_ROOT/index.html"

# Eviter le double-bump : si le dernier commit est deja un bump auto, skip
last_msg=$(git log -1 --pretty=%s 2>/dev/null || echo "")
if [[ "$last_msg" =~ ^Bump\ Flasher ]]; then
    echo "[pre-push] dernier commit est deja un bump, skip."
    exit 0
fi

# 1. Determiner la liste des fichiers modifies dans les commits a pusher
#    Comparaison entre origin/main (ou HEAD distant) et HEAD local.
remote_ref=""
if git rev-parse --verify --quiet "@{push}" >/dev/null 2>&1; then
    remote_ref="@{push}"
elif git rev-parse --verify --quiet "origin/$(git rev-parse --abbrev-ref HEAD)" >/dev/null 2>&1; then
    remote_ref="origin/$(git rev-parse --abbrev-ref HEAD)"
fi

if [[ -z "$remote_ref" ]]; then
    # Premier push d'une nouvelle branche : on prend tous les commits
    base_ref=$(git rev-list --max-parents=0 HEAD)
else
    base_ref="$remote_ref"
fi

# IMPORTANT : on exclut les commits "Bump Flasher #N -> #M" du calcul des
# fichiers modifies. Ces commits sont generes par ce hook lui-meme et ne
# refletent pas une vraie evolution de l'outil. Si la seule difference entre
# base_ref et HEAD est compose de commits release + commits Bump, on ne doit
# PAS bumper a nouveau.
non_bump_commits=$(git log --format='%H %s' "$base_ref..HEAD" | grep -v '^[0-9a-f]\+ Bump Flasher' | awk '{print $1}')

if [[ -z "$non_bump_commits" ]]; then
    # Tous les commits a pusher sont des "Bump" : rien a faire
    changed_files=""
else
    # On regarde les fichiers modifies par les commits NON-Bump uniquement
    changed_files=$(echo "$non_bump_commits" | xargs -I {} git diff-tree --no-commit-id --name-only -r {} 2>/dev/null | sort -u)
fi

if [[ -z "$changed_files" ]]; then
    echo "[pre-push] aucun fichier modifie, rien a faire."
    exit 0
fi

# 2. Regarde si les changements concernent uniquement les releases firmware
#    Patterns "release firmware seulement" : firmware/*, manifests/*, builds.json
#    Tout autre fichier modifie -> c'est une evolution de l'OUTIL flasher
needs_bump=0
flasher_changed_files=""
while IFS= read -r f; do
    case "$f" in
        firmware/*|manifests/*|builds.json|.flasher-version)
            # Release firmware ou bump precedent : ne pas declencher de bump
            ;;
        *)
            # Tout le reste = code de l'outil flasher (index.html, README, scripts, etc.)
            needs_bump=1
            flasher_changed_files+="  - $f"$'\n'
            ;;
    esac
done <<< "$changed_files"

if [[ "$needs_bump" -eq 0 ]]; then
    echo "[pre-push] Release firmware uniquement (firmware/manifests/builds.json) -> pas de bump du compteur Flasher."
    exit 0
fi

# 3. Au moins un fichier de l'outil flasher a change -> on bumpe
echo "[pre-push] Modifications de l'outil flasher detectees :"
echo -n "$flasher_changed_files"

current=0
if [[ -f "$VERSION_FILE" ]]; then
    current=$(cat "$VERSION_FILE" | tr -d '[:space:]')
    if ! [[ "$current" =~ ^[0-9]+$ ]]; then
        current=0
    fi
fi
next=$((current + 1))
echo "$next" > "$VERSION_FILE"

# 4. Maj du tag visuel dans index.html
if [[ -f "$INDEX_HTML" ]] && grep -q "BUILD_TAG_START" "$INDEX_HTML"; then
    timestamp=$(date +"%Y-%m-%d %H:%M")
    short_sha=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    tag_text="Flasher #${next} - ${timestamp} (${short_sha})"
    new_block="<!-- BUILD_TAG_START -->
          <span style=\"font-family:ui-monospace,monospace;font-size:0.75rem;opacity:0.65;\">${tag_text}</span>
          <!-- BUILD_TAG_END -->"
    perl -i -0pe "s|<!-- BUILD_TAG_START -->.*?<!-- BUILD_TAG_END -->|${new_block}|s" "$INDEX_HTML"
fi

# 5. Commit du bump
git add "$VERSION_FILE" "$INDEX_HTML" 2>/dev/null || true
if ! git diff --cached --quiet; then
    git commit -m "Bump Flasher #${current} -> #${next}" --no-verify > /dev/null
    echo "[pre-push] Flasher #${current} -> #${next} (commit ajoute au push)"
else
    echo "[pre-push] aucun changement a commiter (deja a jour ?)"
fi

exit 0
